{
  "name": "hd-printing-packaging-management-system",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace client",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace server",
    "prisma:seed": "npm run prisma:seed --workspace server"
  }
}
